# 当前代码实际支持的运行时环境变量。
# 相对路径以启动进程时的项目根目录为基准。
QUANT_DB_PATH=data/quant_system.db
QUANT_RESEARCH_PATH=data/research

# 数据源必须显式选择。未设置时仅为便于本地开发而使用 demo。
# 可选：demo | csv | licensed-csv | tushare | akshare。
# 非法值或缺少对应配置会阻止服务启动，不会回退 demo。
QUANT_DATA_PROVIDER=akshare
# QUANT_DATA_PATH=D:/data/prototype-bars.csv
# QUANT_DATA_BUNDLE=D:/data/licensed-bundle-20260706

# Tushare Pro：先执行 `uv sync --extra providers`，再仅在本机环境中设置 token。
# 公开接口仅供研究/模拟观察，非 PIT、非生产发布数据；不要把 token 提交到仓库或前端。
# QUANT_TUSHARE_TOKEN=your-local-token
# 含日线与逐日复权因子的完整拉取约 243 次请求，通常约 5 分钟；
# 默认 1.25 秒节流（低于 50 次/分钟）。
# QUANT_TUSHARE_MIN_REQUEST_INTERVAL_SECONDS=1.25

# AKShare：仅原型研究；必须显式限制股票范围，避免把网页数据误作完整市场快照。
QUANT_AKSHARE_SYMBOLS=600519.SH,000858.SZ,000333.SZ,601318.SH,600036.SH,601166.SH,000651.SZ,600276.SH,300760.SZ,300750.SZ,002594.SZ,601012.SH,600900.SH,601088.SH,600028.SH,601857.SH,600030.SH,000001.SZ,002415.SZ,000725.SZ,002230.SZ,603986.SH,000977.SZ,300308.SZ,688981.SH,600309.SH,601899.SH,600887.SH,600809.SH,002475.SZ
QUANT_AKSHARE_MIN_REQUEST_INTERVAL_SECONDS=0.75
QUANT_AKSHARE_METADATA_PATH=deploy/akshare-universe.csv

# 本项目不连接券商；不要在此添加券商账户、交易 API key 或交易证书。
