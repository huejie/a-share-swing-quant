# Copy to .env on the server. Compose already contains safe AKShare defaults;
# only override values that need to differ on this host.
HTTP_PORT=80
QUANT_PUBLIC_ADMIN_ENABLED=false
BACKUP_PATH=/var/backups/a-share-quant
# deploy.sh 首次运行时自动生成；不要提交或复制示例值。
# QUANT_ADMIN_API_KEY=<generated-on-server>
# 外部通知为可选项。目标与凭据仅放在服务器 .env 中，切勿提交。
# QUANT_NOTIFICATION_WEBHOOK_URL=https://example.invalid/private-hook
# QUANT_NOTIFICATION_SMTP_HOST=smtp.example.invalid
# QUANT_NOTIFICATION_SMTP_PORT=587
# QUANT_NOTIFICATION_SMTP_STARTTLS=true
# QUANT_NOTIFICATION_SMTP_USERNAME=
# QUANT_NOTIFICATION_SMTP_PASSWORD=
# QUANT_NOTIFICATION_EMAIL_FROM=
# QUANT_NOTIFICATION_EMAIL_TO=
# QUANT_NOTIFICATION_TIMEOUT_SECONDS=8
# 部署时写入已验收提交；不得用 working-tree 冒充版本。
QUANT_GIT_COMMIT=unknown
QUANT_AKSHARE_MIN_REQUEST_INTERVAL_SECONDS=0.75
QUANT_AKSHARE_DYNAMIC_UNIVERSE=true
QUANT_AKSHARE_DYNAMIC_UNIVERSE_LIMIT=60
QUANT_AKSHARE_MIN_SNAPSHOT_TURNOVER=100000000
QUANT_AKSHARE_MIN_LISTED_DAYS=120

# Dynamic selection is bounded to 60 names. This explicit 30-name universe is
# mandatory as the audited fallback when all-A or industry endpoints fail.
QUANT_AKSHARE_SYMBOLS=600519.SH,000858.SZ,000333.SZ,601318.SH,600036.SH,601166.SH,000651.SZ,600276.SH,300760.SZ,300750.SZ,002594.SZ,601012.SH,600900.SH,601088.SH,600028.SH,601857.SH,600030.SH,000001.SZ,002415.SZ,000725.SZ,002230.SZ,603986.SH,000977.SZ,300308.SZ,688981.SH,600309.SH,601899.SH,600887.SH,600809.SH,002475.SZ
